{
  "name": "@policy-pay/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "pnpm --filter @policy-pay/sdk build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @policy-pay/sdk build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --filter @policy-pay/sdk build && vitest run"
  },
  "dependencies": {
    "@mysten/sui": "^2.16.0",
    "@policy-pay/sdk": "workspace:*",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "pino": "^9.7.0",
    "zod": "^3.25.56",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "vitest": "^3.2.1",
    "@types/node": "^22.15.29"
  }
}
