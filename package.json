{
  "name": "policy-pay-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "media:pitch": "node scripts/build-pitch-media.mjs",
    "verify:product-copy": "node scripts/product-copy-gate.mjs",
    "verify:submission": "node scripts/submission-readiness.mjs",
    "format": "prettier --write .",
    "move:build": "cd move/agent_treasury && sui move build",
    "move:test": "cd move/agent_treasury && sui move test",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next packages/*/dist apps/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
